	func (dao {{$model.DAO}}) UpdateMulti(ctx context.Context, records []{{$model.RecordType}}) error {
		ctx = {{$.AdvPgConnPkg}}.QueryInfoCtx(ctx, {{quote $model.Table.Table}}, "")
		q := queryUpdateMulti{{$model.GoName}}(records)
		{{ if $model.UpdateResultColumns -}}
			rows, err :=dao.db.Query(ctx, q.SQL(), q.Args()...)
			defer rows.Close()

